@page "/invoices/upload"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components

<h1>Upload Invoice</h1>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger" role="alert">
        @Error
    </div>
}

<div class="card" style="max-width: 720px;">
    <div class="card-body">
        <p class="text-muted mb-3">
            Upload a PDF. After upload, the invoice will appear in the Invoices list and be processed in the background.
        </p>

        <form method="post" action="/api/invoices/upload" enctype="multipart/form-data">
            <div class="mb-3">
                <input class="form-control"
                       type="file"
                       name="file"
                       accept=".pdf,application/pdf" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Upload
                </button>

                <a class="btn btn-outline-secondary" href="/invoices">
                    Back to Invoices
                </a>
            </div>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }
}